{
    "name": "tekkom_bot",
    "version": "2.18.5",
    "description": "TekKom Bot",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "start": "bun src/deployCommands.ts; bun src/index.ts",
        "refresh": "bun src/deployCommands.ts",
        "fast": "bun src/index.ts",
        "lint": "eslint ./src",
        "lint:fix": "eslint --fix ./src"
    },
    "author": "Login - Linjeforeningen for IT",
    "license": "MIT",
    "dependencies": {
        "discord.js": "^14.26.4",
        "utilbee": "^1.4.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/bun": "^1.3.14",
        "eslint": "^10.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1"
    },
    "imports": {
        "#constants": "./src/constants.ts",
        "#config": "./src/config.ts",
        "#interfaces": "./src/interfaces.ts",
        "#package": "./package.json",
        "#utils/*": "./src/utils/*",
        "#components/*": "./src/components/*",
        "#managed/*": "./src/managed/*",
        "#commands/*": "./src/commands/*",
        "#/*": "./src/*"
    }
}
