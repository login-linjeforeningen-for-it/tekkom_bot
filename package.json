{
    "name": "tekkom_bot",
    "version": "2.18.1",
    "description": "TekKom Bot",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "start": "bun src/deployCommands.ts; bun src/index.ts",
        "refresh": "bun src/deployCommands.ts",
        "fast": "bun src/index.ts",
        "lint": "eslint ./src",
        "lint:fix": "eslint --fix ./src"
    },
    "author": "Login - Linjeforeningen for IT",
    "license": "MIT",
    "dependencies": {
        "discord.js": "^14.26.3",
        "fs": "^0.0.1-security",
        "node-cron": "^4.2.1",
        "pg": "^8.20.0",
        "utilbee": "^1.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.6.0",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.20.0",
        "eslint": "^10.2.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2"
    },
    "imports": {
        "#constants": "./src/constants.ts",
        "#config": "./src/config.ts",
        "#interfaces": "./src/interfaces.ts",
        "#package": "./package.json",
        "#utils/*": "./src/utils/*",
        "#components/*": "./src/components/*",
        "#managed/*": "./src/managed/*",
        "#commands/*": "./src/commands/*",
        "#/*": "./src/*"
    }
