{
    "name": "tekkom_bot",
    "version": "2.17.0",
    "description": "TekKom Bot",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "start": "node src/deployCommands.ts; node src/index.ts",
        "refresh": "node src/deployCommands.ts",
        "fast": "node src/index.ts",
        "lint": "eslint ./src",
        "lint:fix": "eslint --fix ./src"
    },
    "author": "Login - Linjeforeningen for IT",
    "license": "MIT",
    "dependencies": {
        "discord.js": "^14.25.1",
        "firebase-admin": "^13.7.0",
        "fs": "^0.0.1-security",
        "node-cron": "^4.2.1",
        "pg": "^8.20.0",
        "utilbee": "^1.4.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.5.0",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.20.0",
        "eslint": "^10.1.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    },
    "imports": {
        "#constants": "./src/constants.ts",
        "#config": "./src/config.ts",
        "#interfaces": "./src/interfaces.ts",
        "#package": "./package.json",
        "#utils/*": "./src/utils/*",
